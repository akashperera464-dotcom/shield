// Prisma schema — MongoDB Atlas
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────
// SUBMISSIONS — public "Submit Project" form writes here; admin inbox reads.
// ───────────────────────────────────────────────────────────────────────
model Submission {
  id          String     @id @map("_id")
  name        String
  email       String
  company     String?
  service     String
  timeline    String?
  brief       String
  attachments Json       // SubmissionAttachment[]
  status      String     // "Pending" | "In Progress" | "Under Review" | "Completed"
  createdAt   String     // ISO string — sortable + timezone-safe
  notes       Json?      // ProjectNote[]
  readAt      String?    // ISO timestamp when admin first opened it
  archived    Boolean    @default(false)

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────
// FEEDBACK — client-submitted testimonials. status pending→approved/rejected
// ───────────────────────────────────────────────────────────────────────
model Feedback {
  id        String   @id @map("_id")
  name      String
  role      String
  rating    Int
  quote     String
  variant   String   // "mint" | "violet" | "purple"
  status    String   // "pending" | "approved" | "rejected"
  featured  Boolean  @default(false)
  createdAt String   // ISO timestamp
  source    String?  // "seed" | "client"

  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────
// SHOWCASE — public portfolio cards, editable from SuperAdmin panel.
// ───────────────────────────────────────────────────────────────────────
model Showcase {
  id          String  @id @map("_id")
  title       String
  category    String
  description String
  imageUrl    String
  projectUrl  String
  tags        Json    // string[]
  featured    Boolean @default(false)
  order       Int     @default(0)

  @@index([featured])
  @@index([order])
}

// ───────────────────────────────────────────────────────────────────────
// TEAM — admin users. Superadmin (uid "u_001") is protected.
// ───────────────────────────────────────────────────────────────────────
model TeamMember {
  uid       String @id @map("_id")
  name      String
  email     String @unique
  role      String // "superadmin" | "admin"
  createdAt String
  jobField  String?
  mobile    String?
  username  String?

  @@index([role])
}

// ───────────────────────────────────────────────────────────────────────
// SITE CONFIG — single document storing editable homepage content.
// Always queried by key="global". Updates replace this document.
// ───────────────────────────────────────────────────────────────────────
model SiteConfig {
  id           String @id @map("_id") // always "global"
  heroTitle    String
  heroSubtitle String
  aboutText    String
  contactEmail String
  logoUrl      String
  mainBgUrl    String
  updatedAt    String
}
