// Prisma schema — MongoDB Atlas
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────
// SUBMISSIONS — public "Submit Project" form writes here; admin inbox reads.
// ───────────────────────────────────────────────────────────────────────
model Submission {
  id          String     @id @map("_id")
  name        String
  email       String
  company     String?
  service     String
  timeline    String?
  brief       String
  attachments Json       // SubmissionAttachment[]
  status      String     // "Pending" | "In Progress" | "Under Review" | "Completed"
  createdAt   String     // ISO string — sortable + timezone-safe
  notes       Json?      // ProjectNote[]
  readAt      String?    // ISO timestamp when admin first opened it
  archived    Boolean    @default(false)

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────
// FEEDBACK — client-submitted testimonials. status pending→approved/rejected
// ───────────────────────────────────────────────────────────────────────
model Feedback {
  id        String   @id @map("_id")
  name      String
  role      String
  rating    Int
  quote     String
  variant   String   // "mint" | "violet" | "purple"
  status    String   // "pending" | "approved" | "rejected"
  featured  Boolean  @default(false)
  createdAt String   // ISO timestamp
  source    String?  // "seed" | "client"

  @@index([status])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────
// SHOWCASE — public portfolio cards, editable from SuperAdmin panel.
// ───────────────────────────────────────────────────────────────────────
model Showcase {
  id          String  @id @map("_id")
  title       String
  category    String
  description String
  imageUrl    String
  projectUrl  String
  tags        Json    // string[]
  featured    Boolean @default(false)
  order       Int     @default(0)

  @@index([featured])
  @@index([order])
}

// ───────────────────────────────────────────────────────────────────────
// TEAM — admin users. Superadmin (uid "u_001") is protected.
// ───────────────────────────────────────────────────────────────────────
model TeamMember {
  uid          String @id @map("_id")
  name         String
  email        String @unique
  role         String // "superadmin" | "admin"
  createdAt    String
  jobField     String?
  mobile       String?
  username     String?
  passwordHash String? // bcrypt hash — null for legacy rows, set on create/update

  @@index([role])
}

// ───────────────────────────────────────────────────────────────────────
// SITE CONFIG — single document storing editable homepage content.
// Always queried by key="global". Updates replace this document.
// ───────────────────────────────────────────────────────────────────────
model SiteConfig {
  id           String @id @map("_id") // always "global"
  heroTitle    String
  heroSubtitle String
  aboutText    String
  contactEmail String
  logoUrl      String
  mainBgUrl    String
  updatedAt    String
}

// ───────────────────────────────────────────────────────────────────────
// SESSIONS — server-side session tokens for real auth.
// Cookie holds an opaque token; this collection maps token → admin uid.
// Supports logout-everywhere, expiry, and audit.
// ───────────────────────────────────────────────────────────────────────
model Session {
  id        String   @id @map("_id") // the token itself (32-byte random)
  uid       String   // → TeamMember.uid
  createdAt String
  expiresAt String
  userAgent String?
  ip        String?

  @@index([uid])
  @@index([expiresAt])
}

// ───────────────────────────────────────────────────────────────────────
// ACTIVITY LOG — audit trail. Every admin mutation appends a row.
// ───────────────────────────────────────────────────────────────────────
model ActivityLog {
  id        String   @id @map("_id")
  uid       String   // who did it (TeamMember.uid or "system")
  action    String   // "submission.read" | "feedback.approve" | "team.create" | "showcase.update" | ...
  target    String?  // id of affected entity
  meta      Json?    // arbitrary structured payload
  createdAt String

  @@index([uid])
  @@index([action])
  @@index([createdAt])
}

// ───────────────────────────────────────────────────────────────────────
// ANALYTICS EVENTS — server-side page views + key client actions.
// Each visit is one row. Aggregated by /api/analytics.
// ───────────────────────────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @map("_id")
  kind      String   // "pageview" | "submission_create" | "feedback_submit" | ...
  path      String?
  referrer  String?
  ua        String?
  ip        String?
  createdAt String

  @@index([kind])
  @@index([createdAt])
  @@index([path])
}

// ───────────────────────────────────────────────────────────────────────
// PASSWORD RESET — single-use tokens with expiry.
// ───────────────────────────────────────────────────────────────────────
model PasswordReset {
  id        String   @id @map("_id") // the token itself
  email     String
  createdAt String
  expiresAt String
  usedAt    String?

  @@index([email])
  @@index([expiresAt])
}
